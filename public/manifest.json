{
  "manifest_version": 3,
  "name": "SonTab",
  "version": "0.1.0",
  "description": "__MSG_appDesc__",
  "default_locale": "en",
  "homepage_url": "https://martianlee.github.io/sontab/",
  "permissions": ["tabs", "storage", "unlimitedStorage", "alarms", "contextMenus"],
  "commands": {
    "collect-window": {
      "suggested_key": { "default": "Ctrl+Shift+S", "mac": "Command+Shift+S" },
      "description": "__MSG_cmdCollectWindow__"
    },
    "collect-tab": {
      "suggested_key": { "default": "Ctrl+Shift+X", "mac": "Command+Shift+X" },
      "description": "__MSG_cmdCollectTab__"
    }
  },
  "background": { "service_worker": "background.js", "type": "module" },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
